<Window
    x:Class="VideoArchive.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VideoArchive"
    xmlns:views="using:VideoArchive.Views"
    Title="Video Archive">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Main NavigationView area -->
            <ColumnDefinition Width="*" />
            <!-- Collapsible TabsPanel (only visible in Search & Playback) -->
            <ColumnDefinition x:Name="TabsPanelColumn" Width="Auto" />
        </Grid.ColumnDefinitions>

        <NavigationView x:Name="NavView"
                        Grid.Column="0"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        IsPaneOpen="False"
                        SelectionChanged="NavView_SelectionChanged">

            <!-- Navigation items -->
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Search &amp; Playback" Tag="SearchPlayback">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Tag Management" Tag="TagManagement">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE1CB;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Content panels — only one visible at a time -->
            <Grid>
                <!-- Search & Playback host -->
                <Grid x:Name="SearchPlaybackHost">
                    <views:SearchPanel x:Name="SearchPanelControl" />
                    <views:PlayerPanel x:Name="PlayerPanelControl" Visibility="Collapsed" />
                </Grid>

                <!-- Tag Management panel -->
                <views:TagsPanel x:Name="TagsPanelControl" Visibility="Collapsed" />

                <!-- Settings panel -->
                <views:SettingsPanel x:Name="SettingsPanelControl" Visibility="Collapsed" />
            </Grid>

        </NavigationView>

        <!-- TabsPanel — right column, visible only in Search & Playback -->
        <views:TabsPanel x:Name="TabsPanelControl"
                         Grid.Column="1" />

    </Grid>
</Window>
