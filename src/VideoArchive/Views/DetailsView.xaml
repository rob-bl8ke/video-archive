<UserControl
    x:Class="VideoArchive.Views.DetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:VideoArchive.Converters">

    <UserControl.Resources>
        <converters:StringToImageSourceConverter x:Key="ImageConverter" />
        <converters:DurationConverter x:Key="DurationConverter" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:DateTimeConverter x:Key="DateTimeConverter" />
        <converters:TagsJoinConverter x:Key="TagsJoinConverter" />
    </UserControl.Resources>

    <Grid Padding="12">
        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   Text="No videos yet — add a folder and click Refresh."
                   Style="{ThemeResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed" />

        <controls:DataGrid x:Name="VideosGrid"
                           AutoGenerateColumns="False"
                           IsReadOnly="True"
                           SelectionMode="Single"
                           GridLinesVisibility="Horizontal"
                           CanUserSortColumns="True"
                           Sorting="VideosGrid_Sorting"
                           SelectionChanged="VideosGrid_SelectionChanged"
                           VerticalAlignment="Stretch"
                           HorizontalAlignment="Stretch">

            <controls:DataGrid.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Play" Click="PlayMenuItem_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE768;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Add Tags" Click="AddTagsMenuItem_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE1CB;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Remove from Library" Click="RemoveMenuItem_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE74D;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </controls:DataGrid.ContextFlyout>

            <controls:DataGrid.Columns>
                <!-- Thumbnail -->
                <controls:DataGridTemplateColumn Header="" Width="80" CanUserSort="False">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImageConverter}}"
                                   Width="70" Height="40"
                                   Stretch="UniformToFill"
                                   Margin="4,2" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Title -->
                <controls:DataGridTextColumn Header="Title"
                                             Binding="{Binding Title}"
                                             Width="*"
                                             Tag="Title" />

                <!-- Duration -->
                <controls:DataGridTemplateColumn Header="Duration" Width="80" Tag="Duration">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Duration, Converter={StaticResource DurationConverter}}"
                                       VerticalAlignment="Center"
                                       Margin="8,0" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Format -->
                <controls:DataGridTextColumn Header="Format"
                                             Binding="{Binding Format}"
                                             Width="70"
                                             Tag="Format" />

                <!-- Resolution -->
                <controls:DataGridTextColumn Header="Resolution"
                                             Binding="{Binding Resolution}"
                                             Width="100"
                                             Tag="Resolution" />

                <!-- Tags -->
                <controls:DataGridTemplateColumn Header="Tags" Width="150" CanUserSort="False">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding VideoTags, Converter={StaticResource TagsJoinConverter}}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="8,0" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Date Added -->
                <controls:DataGridTemplateColumn Header="Date Added" Width="140" Tag="DateAdded">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateAdded, Converter={StaticResource DateTimeConverter}}"
                                       VerticalAlignment="Center"
                                       Margin="8,0" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- File Size -->
                <controls:DataGridTemplateColumn Header="Size" Width="90" Tag="FileSize">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                       VerticalAlignment="Center"
                                       Margin="8,0" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>
    </Grid>
</UserControl>
