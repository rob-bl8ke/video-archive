<UserControl
    x:Class="VideoArchive.Views.SearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VideoArchive.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Padding="8,6">

            <!-- Search -->
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Search videos..."
                            QueryIcon="Find"
                            Width="250"
                            VerticalAlignment="Center"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted" />

            <!-- View toggles -->
            <AppBarSeparator />
            <ToggleButton x:Name="GalleryToggle"
                          IsChecked="{x:Bind ViewModel.IsGalleryView, Mode=TwoWay}"
                          ToolTipService.ToolTip="Gallery View"
                          Padding="8">
                <FontIcon Glyph="&#xE8A9;" FontSize="16" />
            </ToggleButton>
            <ToggleButton x:Name="DetailsToggle"
                          Click="DetailsToggle_Click"
                          ToolTipService.ToolTip="Details View"
                          Padding="8">
                <FontIcon Glyph="&#xE14C;" FontSize="16" />
            </ToggleButton>

        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <local:GalleryView x:Name="GalleryViewControl" />
            <local:DetailsView x:Name="DetailsViewControl" />
        </Grid>

    </Grid>
</UserControl>
