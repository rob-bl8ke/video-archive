<UserControl
    x:Class="VideoArchive.Views.SegmentPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:VideoArchive.Converters">

    <UserControl.Resources>
        <converters:PreciseDurationConverter x:Key="PreciseDuration" />
    </UserControl.Resources>

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Segments"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button x:Name="AddButton"
                    Click="AddSegment_Click"
                    ToolTipService.ToolTip="Add segment at current time"
                    Padding="4">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </StackPanel>

        <!-- Segment list -->
        <ListView x:Name="SegmentsList"
                  Grid.Row="1"
                  SelectionMode="None"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,4,4,4" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,2"
                            Tapped="SegmentCard_Tapped">
                        <Grid RowSpacing="4" Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Read-only name -->
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- Row 1: Start (left) and End (right) on one row -->
                            <Grid Grid.Row="1" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Left group: Start label + start times, hugs left -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Start"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="11" />
                                    <TextBlock Text="{Binding StartTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Right group: end times + End label, hugs right -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EndTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="End"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontSize="11" />
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Delete -->
                            <Grid Grid.Row="2" Margin="0,2,0,0" Background="Transparent">
                                <Button Click="DeleteSegment_Click"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="Delete segment"
                                        HorizontalAlignment="Right"
                                        Padding="4,2">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE74D;" FontSize="10"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        <TextBlock Text="Delete" FontSize="10"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
