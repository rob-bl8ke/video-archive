<UserControl
    x:Class="VideoArchive.Views.SegmentPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:VideoArchive.Converters">

    <UserControl.Resources>
        <converters:PreciseDurationConverter x:Key="PreciseDuration" />
    </UserControl.Resources>

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Segments"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button x:Name="AddButton"
                    Click="AddSegment_Click"
                    ToolTipService.ToolTip="Add segment at current time"
                    Padding="4">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </StackPanel>

        <!-- Segment list -->
        <ListView x:Name="SegmentsList"
                  Grid.Row="1"
                  SelectionMode="None"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,4,4,4" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,2"
                            Tapped="SegmentCard_Tapped">
                        <Grid RowSpacing="4" Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Editable name -->
                            <TextBox Grid.Row="0"
                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Segment name"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Padding="4,2"
                                     BorderThickness="0,0,0,1"
                                     GotFocus="SegmentName_GotFocus"
                                     LostFocus="SegmentName_LostFocus"
                                     KeyDown="SegmentName_KeyDown"
                                     Tag="{Binding}" />

                            <!-- Row 1: Start time -->
                            <Grid Grid.Row="1" ColumnSpacing="2" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Start"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="11" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StartTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas" />
                                    <TextBlock AutomationProperties.Name="start-timecode"
                                               Text="--:--:--:--"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="10"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                            </Grid>

                            <!-- Row 2: End time -->
                            <Grid Grid.Row="2" ColumnSpacing="2" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="End"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="11" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EndTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas" />
                                    <TextBlock AutomationProperties.Name="end-timecode"
                                               Text="--:--:--:--"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="10"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                            <!-- Row 3: Delete -->
                            <Grid Grid.Row="3" Margin="0,2,0,0" Background="Transparent">
                                <Button Click="DeleteSegment_Click"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="Delete segment"
                                        HorizontalAlignment="Right"
                                        Padding="4,2">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE74D;" FontSize="10"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        <TextBlock Text="Delete" FontSize="10"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
