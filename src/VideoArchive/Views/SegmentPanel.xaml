<UserControl
    x:Class="VideoArchive.Views.SegmentPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:VideoArchive.Converters">

    <UserControl.Resources>
        <converters:PreciseDurationConverter x:Key="PreciseDuration" />
    </UserControl.Resources>

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Segments"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button x:Name="AddButton"
                    Click="AddSegment_Click"
                    ToolTipService.ToolTip="Add segment at current time"
                    Padding="4">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </StackPanel>

        <!-- Segment list -->
        <ListView x:Name="SegmentsList"
                  Grid.Row="1"
                  SelectionMode="None"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,4,4,4" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,2">
                        <Grid RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: Editable name -->
                            <TextBox Grid.Row="0"
                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Segment name"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Padding="4,2"
                                     BorderThickness="0,0,0,1"
                                     LostFocus="SegmentName_LostFocus"
                                     KeyDown="SegmentName_KeyDown"
                                     Tag="{Binding}" />

                            <!-- Row 1: Start time with adjustments -->
                            <Grid Grid.Row="1" ColumnSpacing="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Start"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="11" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StartTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas" />
                                    <TextBlock AutomationProperties.Name="start-timecode"
                                               Text="--:--:--:--"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="10"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <!-- 2-row × 5-col uniform button grid -->
                                <Grid Grid.Column="2" RowSpacing="1" ColumnSpacing="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Coarse row: −5 | −1 | ⊙ | +1 | +5 -->
                                    <Button Grid.Row="0" Grid.Column="0"
                                            Click="AdjustStartMinus5_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start −5s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−5" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Click="AdjustStartMinus1_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start −1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Click="SetStartFromPlayhead_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Set start to current time"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <FontIcon Glyph="&#xE892;" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="3"
                                            Click="AdjustStartPlus1_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start +1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="4"
                                            Click="AdjustStartPlus5_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start +5s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+5" FontSize="10" />
                                    </Button>

                                    <!-- Fine row: −1f | −.1 | (empty) | +.1 | +1f -->
                                    <Button Grid.Row="1" Grid.Column="0"
                                            Click="AdjustStartMinus1Frame_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start −1 frame"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−1f" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1"
                                            Click="AdjustStartMinusTenth_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start −0.1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−.1" FontSize="10" />
                                    </Button>
                                    <!-- col 2 intentionally empty (aligns with playhead button above) -->
                                    <Button Grid.Row="1" Grid.Column="3"
                                            Click="AdjustStartPlusTenth_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start +0.1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+.1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="4"
                                            Click="AdjustStartPlus1Frame_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Start +1 frame"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+1f" FontSize="10" />
                                    </Button>
                                </Grid>
                            </Grid>

                            <!-- Row 2: End time with adjustments -->
                            <Grid Grid.Row="2" ColumnSpacing="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="End"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="11" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EndTime, Converter={StaticResource PreciseDuration}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="11"
                                               FontFamily="Consolas" />
                                    <TextBlock AutomationProperties.Name="end-timecode"
                                               Text="--:--:--:--"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               FontSize="10"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <!-- 2-row × 5-col uniform button grid -->
                                <Grid Grid.Column="2" RowSpacing="1" ColumnSpacing="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Coarse row: −5 | −1 | ⊙ | +1 | +5 -->
                                    <Button Grid.Row="0" Grid.Column="0"
                                            Click="AdjustEndMinus5_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End −5s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−5" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Click="AdjustEndMinus1_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End −1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Click="SetEndFromPlayhead_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Set end to current time"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <FontIcon Glyph="&#xE893;" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="3"
                                            Click="AdjustEndPlus1_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End +1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="4"
                                            Click="AdjustEndPlus5_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End +5s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+5" FontSize="10" />
                                    </Button>

                                    <!-- Fine row: −1f | −.1 | (empty) | +.1 | +1f -->
                                    <Button Grid.Row="1" Grid.Column="0"
                                            Click="AdjustEndMinus1Frame_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End −1 frame"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−1f" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1"
                                            Click="AdjustEndMinusTenth_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End −0.1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="−.1" FontSize="10" />
                                    </Button>
                                    <!-- col 2 intentionally empty (aligns with playhead button above) -->
                                    <Button Grid.Row="1" Grid.Column="3"
                                            Click="AdjustEndPlusTenth_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End +0.1s"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+.1" FontSize="10" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="4"
                                            Click="AdjustEndPlus1Frame_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="End +1 frame"
                                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0"
                                            HorizontalContentAlignment="Center">
                                        <TextBlock Text="+1f" FontSize="10" />
                                    </Button>
                                </Grid>
                            </Grid>

                            <!-- Row 3: Segment transport + Delete -->
                            <Grid Grid.Row="3" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Transport buttons -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                    <Button Click="SegmentPlayPause_Click" Tag="{Binding}"
                                            AutomationProperties.Name="segment-play"
                                            ToolTipService.ToolTip="Play / Pause segment"
                                            Padding="4,2" MinWidth="0" MinHeight="0">
                                        <FontIcon Glyph="&#xE768;" FontSize="12" />
                                    </Button>
                                    <Button Click="SegmentStop_Click" Tag="{Binding}"
                                            ToolTipService.ToolTip="Stop segment playback"
                                            Padding="4,2" MinWidth="0" MinHeight="0">
                                        <FontIcon Glyph="&#xE71A;" FontSize="12" />
                                    </Button>
                                    <ToggleButton Click="SegmentToggleLoop_Click" Tag="{Binding}"
                                                  ToolTipService.ToolTip="Toggle loop"
                                                  Padding="4,2" MinWidth="0" MinHeight="0">
                                        <FontIcon Glyph="&#xE8EE;" FontSize="12" />
                                    </ToggleButton>
                                </StackPanel>

                                <!-- Delete button -->
                                <Button Grid.Column="1"
                                        Click="DeleteSegment_Click"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="Delete segment"
                                        HorizontalAlignment="Right"
                                        Padding="4,2">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE74D;" FontSize="10"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        <TextBlock Text="Delete" FontSize="10"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
