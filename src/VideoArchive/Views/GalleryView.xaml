<UserControl
    x:Class="VideoArchive.Views.GalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:VideoArchive.Converters"
    xmlns:local="using:VideoArchive.Views"
    xmlns:models="using:VideoArchive.Models">

    <UserControl.Resources>
        <converters:StringToImageSourceConverter x:Key="ImageConverter" />
        <converters:DurationConverter x:Key="DurationConverter" />
        <converters:ColorHexToBrushConverter x:Key="ColorBrushConverter" />
    </UserControl.Resources>

    <Grid Padding="12">
        <!-- Empty state -->
        <StackPanel x:Name="EmptyPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xE8B7;"
                      FontSize="48"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock x:Name="EmptyText"
                       Text="No videos yet — add a folder and click Refresh to get started."
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Name="EmptyHint"
                       Text="Use the toolbar above or go to Settings to add library folders."
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
        </StackPanel>

        <GridView x:Name="VideoGrid"
                  SelectionMode="Single"
                  SelectionChanged="VideoGrid_SelectionChanged"
                  DoubleTapped="VideoGrid_DoubleTapped"
                  Padding="0"
                  Margin="0,0,0,12">
            <GridView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Play" Icon="Play" Click="PlayMenuItem_Click" />
                </MenuFlyout>
            </GridView.ContextFlyout>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:ItemsWrapGrid Orientation="Horizontal"
                                            MaximumRowsOrColumns="20"
                                            ItemWidth="240"
                                            ItemHeight="220" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="BorderThickness" Value="3" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="CornerRadius" Value="6" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Video">
                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          CornerRadius="4"
                          Padding="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="124" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Thumbnail with duration badge -->
                        <Grid Grid.Row="0" Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}">
                            <Image Source="{x:Bind ThumbnailPath, Converter={StaticResource ImageConverter}}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <!-- Placeholder icon when no thumbnail -->
                            <FontIcon Glyph="&#xE8B2;"
                                      FontSize="36"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind local:GalleryView.NoThumbnailVisibility(ThumbnailPath)}" />

                            <!-- Duration badge -->
                            <Border Background="#CC000000"
                                    CornerRadius="2"
                                    Padding="4,2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,6,6">
                                <TextBlock Text="{x:Bind Duration, Converter={StaticResource DurationConverter}}"
                                           FontSize="11"
                                           Foreground="White" />
                            </Border>
                        </Grid>

                        <!-- Title + Tags -->
                        <StackPanel Grid.Row="1" Padding="8,6,8,8" Spacing="4">
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis">
                                <Run Text="{x:Bind Format}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind Resolution}" />
                            </TextBlock>

                            <!-- Tag chips -->
                            <ItemsRepeater ItemsSource="{x:Bind VideoTags}">
                                <ItemsRepeater.Layout>
                                    <controls:StackLayout Orientation="Horizontal" Spacing="4" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:VideoTag">
                                        <Border Background="{x:Bind Tag.Color, Converter={StaticResource ColorBrushConverter}}"
                                                CornerRadius="8"
                                                Padding="6,2"
                                                Opacity="0.85">
                                            <TextBlock Text="{x:Bind Tag.Name}"
                                                       FontSize="10"
                                                       Foreground="White" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</UserControl>
