<UserControl
    x:Class="VideoArchive.Views.GalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:VideoArchive.Converters"
    xmlns:local="using:VideoArchive.Views"
    xmlns:models="using:VideoArchive.Models">

    <UserControl.Resources>
        <converters:StringToImageSourceConverter x:Key="ImageConverter" />
        <converters:DurationConverter x:Key="DurationConverter" />
        <converters:ColorHexToBrushConverter x:Key="ColorBrushConverter" />
    </UserControl.Resources>

    <Grid Padding="12">
        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   Text="No videos yet — add a folder and click Refresh."
                   Style="{ThemeResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed" />

        <ScrollViewer x:Name="GalleryScroller"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="VideoRepeater"
                           Margin="0,0,0,12">
                <ItemsRepeater.Layout>
                    <controls:UniformGridLayout MinItemWidth="220"
                                                MinItemHeight="200"
                                                MinColumnSpacing="8"
                                                MinRowSpacing="8"
                                                ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:Video">
                        <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="4"
                              Padding="0"
                              PointerPressed="Card_PointerPressed"
                              Tag="{x:Bind Id}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="124" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Thumbnail with duration badge -->
                            <Grid Grid.Row="0" Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}">
                                <Image Source="{x:Bind ThumbnailPath, Converter={StaticResource ImageConverter}}"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                                <!-- Placeholder icon when no thumbnail -->
                                <FontIcon Glyph="&#xE8B2;"
                                          FontSize="36"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{x:Bind local:GalleryView.NoThumbnailVisibility(ThumbnailPath)}" />

                                <!-- Duration badge -->
                                <Border Background="#CC000000"
                                        CornerRadius="2"
                                        Padding="4,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,6,6">
                                    <TextBlock Text="{x:Bind Duration, Converter={StaticResource DurationConverter}}"
                                               FontSize="11"
                                               Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- Title + Tags -->
                            <StackPanel Grid.Row="1" Padding="8,6,8,8" Spacing="4">
                                <TextBlock Text="{x:Bind Title}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{x:Bind Format}" />
                                    <Run Text=" · " />
                                    <Run Text="{x:Bind Resolution}" />
                                </TextBlock>

                                <!-- Tag chips -->
                                <ItemsRepeater ItemsSource="{x:Bind VideoTags}">
                                    <ItemsRepeater.Layout>
                                        <controls:StackLayout Orientation="Horizontal" Spacing="4" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:VideoTag">
                                            <Border Background="{x:Bind Tag.Color, Converter={StaticResource ColorBrushConverter}}"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Opacity="0.85">
                                                <TextBlock Text="{x:Bind Tag.Name}"
                                                           FontSize="10"
                                                           Foreground="White" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
