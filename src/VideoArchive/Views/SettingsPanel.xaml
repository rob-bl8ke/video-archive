<UserControl
    x:Class="VideoArchive.Views.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Settings"
                       Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Library Folders -->
            <StackPanel Spacing="8">
                <TextBlock Text="Library Folders"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Manage the folders that are scanned for video files."
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ListView x:Name="FoldersList"
                          MaxHeight="200"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Path}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LastScanned}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Click="RemoveFolder_Click"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="Remove folder"
                                        Padding="6,4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="AddFolder_Click"
                            Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8F4;" FontSize="14" />
                            <TextBlock Text="Add Folder" />
                        </StackPanel>
                    </Button>
                    <Button Click="RefreshLibrary_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh Library" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Thumbnail Management -->
            <StackPanel Spacing="8">
                <TextBlock Text="Thumbnails"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Manage video thumbnail images stored in the app data folder."
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="CleanThumbnails_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            <TextBlock Text="Clean Thumbnail Cache" />
                        </StackPanel>
                    </Button>
                    <Button Click="RebuildThumbnails_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="Rebuild All Thumbnails" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="Appearance"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Theme" VerticalAlignment="Center" />
                    <ComboBox x:Name="ThemeCombo"
                              Width="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="System Default" Tag="Default" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Segments -->
            <StackPanel Spacing="8">
                <TextBlock Text="Segments"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Configure default durations for video segments."
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Grid ColumnSpacing="16" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Default segment duration (seconds)"
                               VerticalAlignment="Center" />
                    <NumberBox x:Name="DefaultDurationBox"
                               Grid.Row="0" Grid.Column="1"
                               Width="100"
                               Minimum="1" Maximum="300"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="DefaultDurationBox_ValueChanged" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Minimum segment duration (seconds)"
                               VerticalAlignment="Center" />
                    <NumberBox x:Name="MinDurationBox"
                               Grid.Row="1" Grid.Column="1"
                               Width="100"
                               Minimum="1" Maximum="60"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="MinDurationBox_ValueChanged" />
                </Grid>
            </StackPanel>

            <!-- Status -->
            <TextBlock x:Name="StatusText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
