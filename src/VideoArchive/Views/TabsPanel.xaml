<UserControl
    x:Class="VideoArchive.Views.TabsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VideoArchive.Views">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Collapse toggle strip — always visible -->
            <ColumnDefinition Width="Auto" />
            <!-- Tab content — hidden when collapsed -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Collapse/expand toggle strip -->
        <Border Grid.Column="0"
                Width="32"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0">
            <ToggleButton x:Name="CollapseToggle"
                          IsChecked="{x:Bind ViewModel.IsTabsPanelCollapsed, Mode=TwoWay}"
                          ToolTipService.ToolTip="Show/Hide side panel"
                          Padding="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,8,0,0"
                          Background="Transparent"
                          BorderThickness="0">
                <FontIcon x:Name="CollapseIcon" Glyph="&#xE76C;" FontSize="12" />
            </ToggleButton>
        </Border>

        <!-- Tab content -->
        <Pivot x:Name="TabPivot"
               Grid.Column="1"
               Width="340"
               Background="{ThemeResource LayerFillColorDefaultBrush}">

            <PivotItem x:Name="TagsPivotItem" Header="Tags">
                <local:TagPanel />
            </PivotItem>

            <PivotItem x:Name="SegmentsPivotItem" Header="Segments">
                <local:SegmentPanel />
            </PivotItem>

        </Pivot>

    </Grid>
</UserControl>
