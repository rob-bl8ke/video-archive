<UserControl
    x:Class="VideoArchive.Views.PlayerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="0,1,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdjustPanelStates">
                <VisualState x:Name="AdjustWide" />
                <VisualState x:Name="AdjustNarrow">
                    <VisualState.Setters>
                        <Setter Target="AdjStartTimecode.Visibility" Value="Collapsed" />
                        <Setter Target="AdjEndTimecode.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="AdjustCompact">
                    <VisualState.Setters>
                        <Setter Target="AdjStartTime.Visibility" Value="Collapsed" />
                        <Setter Target="AdjStartTimecode.Visibility" Value="Collapsed" />
                        <Setter Target="AdjEndTime.Visibility" Value="Collapsed" />
                        <Setter Target="AdjEndTimecode.Visibility" Value="Collapsed" />
                        <Setter Target="StartMinus5Button.Visibility" Value="Collapsed" />
                        <Setter Target="StartPlus5Button.Visibility" Value="Collapsed" />
                        <Setter Target="EndMinus5Button.Visibility" Value="Collapsed" />
                        <Setter Target="EndPlus5Button.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Back to search header -->
        <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Button x:Name="BackToSearchButton"
                    Click="BackToSearch_Click"
                    ToolTipService.ToolTip="Back to Search"
                    Padding="6,4"
                    Background="Transparent"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="Back to Search" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Video surface area (native popup window renders on top of this) -->
        <Border x:Name="VideoSurface"
                Grid.Row="1"
                Background="Black"
                MinHeight="180"
                SizeChanged="VideoSurface_SizeChanged"
                DoubleTapped="VideoSurface_DoubleTapped">
            <!-- "No video" placeholder -->
            <StackPanel x:Name="NoVideoPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE714;"
                          FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Select a video to preview it here"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Now playing + seek bar -->
        <Grid Grid.Row="2" Padding="12,8,12,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="NowPlayingText"
                       Grid.Row="0"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <Slider x:Name="SeekSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="1"
                        StepFrequency="0.001"
                        ThumbToolTipValueConverter="{x:Null}"
                        ValueChanged="SeekSlider_ValueChanged"
                        VerticalAlignment="Center" />

                <TextBlock x:Name="TotalTimeText"
                           Grid.Column="2"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Grid>

        <!-- Transport controls -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Padding="0,4,0,8">

            <Button x:Name="PlayPauseButton"
                    Click="PlayPause_Click"
                    ToolTipService.ToolTip="Play / Pause"
                    Padding="12,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="20" />
            </Button>

            <ToggleButton x:Name="LoopButton"
                          Click="LoopToggle_Click"
                          ToolTipService.ToolTip="Loop"
                          Padding="8">
                <FontIcon Glyph="&#xE8EE;" FontSize="16" />
            </ToggleButton>

            <AppBarSeparator />

            <!-- Volume -->
            <FontIcon Glyph="&#xE767;" FontSize="14" VerticalAlignment="Center" />
            <Slider x:Name="VolumeSlider"
                    Width="100"
                    Minimum="0" Maximum="100"
                    Value="80"
                    ValueChanged="VolumeSlider_ValueChanged"
                    VerticalAlignment="Center" />

            <AppBarSeparator />

            <!-- Fullscreen toggle -->
            <Button x:Name="FullscreenButton"
                    Click="Fullscreen_Click"
                    ToolTipService.ToolTip="Fullscreen (double-click video or press Escape to exit)"
                    Padding="8">
                <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="16" />
            </Button>
        </StackPanel>

        <!-- Segment adjustment controls (visible when a segment is selected) -->
        <Border x:Name="SegmentAdjustPanel"
                Grid.Row="4"
                Visibility="Collapsed"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="12,8,12,10">
            <!-- Single row: [start time][start buttons][segment name][end buttons][end time] -->
            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Col 0: Start time + timecode -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="AdjStartTime"
                               Text="--:--"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontSize="11"
                               FontFamily="Consolas" />
                    <TextBlock x:Name="AdjStartTimecode"
                               Text="--:--:--:--"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontSize="10"
                               FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Col 1: Start adjustment buttons (2-row × 5-col) -->
                <Grid Grid.Column="1" RowSpacing="1" ColumnSpacing="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                    </Grid.ColumnDefinitions>

                    <!-- Coarse row -->
                    <Button x:Name="StartMinus5Button" Grid.Row="0" Grid.Column="0" Click="AdjustStartMinus5_Click"
                            ToolTipService.ToolTip="Start −5s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−5" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1" Click="AdjustStartMinus1_Click"
                            ToolTipService.ToolTip="Start −1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−1" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="2" Click="SetStartFromPlayhead_Click"
                            ToolTipService.ToolTip="Set start to current time"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <FontIcon Glyph="&#xE892;" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="3" Click="AdjustStartPlus1_Click"
                            ToolTipService.ToolTip="Start +1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+1" FontSize="10" />
                    </Button>
                    <Button x:Name="StartPlus5Button" Grid.Row="0" Grid.Column="4" Click="AdjustStartPlus5_Click"
                            ToolTipService.ToolTip="Start +5s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+5" FontSize="10" />
                    </Button>

                    <!-- Fine row -->
                    <Button Grid.Row="1" Grid.Column="0" Click="AdjustStartMinus1Frame_Click"
                            ToolTipService.ToolTip="Start −1 frame"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−1f" FontSize="10" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="1" Click="AdjustStartMinusTenth_Click"
                            ToolTipService.ToolTip="Start −0.1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−.1" FontSize="10" />
                    </Button>
                    <!-- col 2 empty -->
                    <Button Grid.Row="1" Grid.Column="3" Click="AdjustStartPlusTenth_Click"
                            ToolTipService.ToolTip="Start +0.1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+.1" FontSize="10" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="4" Click="AdjustStartPlus1Frame_Click"
                            ToolTipService.ToolTip="Start +1 frame"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+1f" FontSize="10" />
                    </Button>
                </Grid>

                <!-- Col 2: Segment name — label + pencil toggle, or TextBox in edit mode -->
                <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel x:Name="SegmentNameLabelPanel"
                                Orientation="Horizontal" Spacing="4"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="SegmentNameLabel"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="120"
                                   VerticalAlignment="Center" />
                        <Button x:Name="EditSegmentNameButton"
                                Click="EditSegmentName_Click"
                                ToolTipService.ToolTip="Rename segment"
                                Padding="4"
                                Width="22" Height="22"
                                Background="Transparent"
                                BorderThickness="0"
                                MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE70F;" FontSize="10" />
                        </Button>
                    </StackPanel>
                    <TextBox x:Name="SegmentNameEditor"
                             Visibility="Collapsed"
                             MinWidth="80" MaxWidth="160"
                             FontSize="11"
                             Padding="4,2"
                             HorizontalAlignment="Center"
                             LostFocus="SegmentNameEditor_LostFocus"
                             KeyDown="SegmentNameEditor_KeyDown" />
                </Grid>

                <!-- Col 3: End adjustment buttons (2-row × 5-col) -->
                <Grid Grid.Column="3" RowSpacing="1" ColumnSpacing="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="28" />
                    </Grid.ColumnDefinitions>

                    <!-- Coarse row -->
                    <Button x:Name="EndMinus5Button" Grid.Row="0" Grid.Column="0" Click="AdjustEndMinus5_Click"
                            ToolTipService.ToolTip="End −5s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−5" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1" Click="AdjustEndMinus1_Click"
                            ToolTipService.ToolTip="End −1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−1" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="2" Click="SetEndFromPlayhead_Click"
                            ToolTipService.ToolTip="Set end to current time"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <FontIcon Glyph="&#xE893;" FontSize="10" />
                    </Button>
                    <Button Grid.Row="0" Grid.Column="3" Click="AdjustEndPlus1_Click"
                            ToolTipService.ToolTip="End +1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+1" FontSize="10" />
                    </Button>
                    <Button x:Name="EndPlus5Button" Grid.Row="0" Grid.Column="4" Click="AdjustEndPlus5_Click"
                            ToolTipService.ToolTip="End +5s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+5" FontSize="10" />
                    </Button>

                    <!-- Fine row -->
                    <Button Grid.Row="1" Grid.Column="0" Click="AdjustEndMinus1Frame_Click"
                            ToolTipService.ToolTip="End −1 frame"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−1f" FontSize="10" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="1" Click="AdjustEndMinusTenth_Click"
                            ToolTipService.ToolTip="End −0.1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="−.1" FontSize="10" />
                    </Button>
                    <!-- col 2 empty -->
                    <Button Grid.Row="1" Grid.Column="3" Click="AdjustEndPlusTenth_Click"
                            ToolTipService.ToolTip="End +0.1s"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+.1" FontSize="10" />
                    </Button>
                    <Button Grid.Row="1" Grid.Column="4" Click="AdjustEndPlus1Frame_Click"
                            ToolTipService.ToolTip="End +1 frame"
                            Width="28" Height="22" Padding="0" MinWidth="0" MinHeight="0" HorizontalContentAlignment="Center">
                        <TextBlock Text="+1f" FontSize="10" />
                    </Button>
                </Grid>

                <!-- Col 4: End time + timecode -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="AdjEndTime"
                               Text="--:--"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontSize="11"
                               FontFamily="Consolas"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="AdjEndTimecode"
                               Text="--:--:--:--"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontSize="10"
                               FontFamily="Consolas"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
