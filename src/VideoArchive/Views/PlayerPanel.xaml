<UserControl
    x:Class="VideoArchive.Views.PlayerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:VideoArchive.Converters">

    <UserControl.Resources>
        <converters:DurationConverter x:Key="DurationConverter" />
    </UserControl.Resources>

    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="0,1,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Video surface area (native child window renders here) -->
        <Border x:Name="VideoSurface"
                Grid.Row="0" Grid.Column="0"
                Background="Black"
                MinHeight="180"
                SizeChanged="VideoSurface_SizeChanged">
            <!-- "No video" placeholder -->
            <StackPanel x:Name="NoVideoPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE714;"
                          FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Select a video and click Play"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Segments panel (right side) -->
        <Grid Grid.Row="0" Grid.Column="1"
              Width="220"
              Padding="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Segments"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center" />
                <Button Click="AddSegment_Click"
                        ToolTipService.ToolTip="Add segment at current time"
                        Padding="4">
                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                </Button>
            </StackPanel>

            <ListView x:Name="SegmentsList"
                      Grid.Row="1"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,4" ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           FontWeight="SemiBold" />
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding StartTime, Converter={StaticResource DurationConverter}}" />
                                    <Run Text=" → " />
                                    <Run Text="{Binding EndTime, Converter={StaticResource DurationConverter}}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                <Button Click="SetStartTime_Click" Tag="{Binding}"
                                        ToolTipService.ToolTip="Set start to current time"
                                        Padding="4">
                                    <FontIcon Glyph="&#xE892;" FontSize="10" />
                                </Button>
                                <Button Click="SetEndTime_Click" Tag="{Binding}"
                                        ToolTipService.ToolTip="Set end to current time"
                                        Padding="4">
                                    <FontIcon Glyph="&#xE893;" FontSize="10" />
                                </Button>
                                <Button Click="DeleteSegment_Click" Tag="{Binding}"
                                        ToolTipService.ToolTip="Delete segment"
                                        Padding="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Now playing + seek bar -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Padding="12,8,12,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="NowPlayingText"
                       Grid.Row="0"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <Slider x:Name="SeekSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="1"
                        StepFrequency="0.001"
                        ThumbToolTipValueConverter="{x:Null}"
                        ManipulationStarting="SeekSlider_ManipulationStarting"
                        ManipulationCompleted="SeekSlider_ManipulationCompleted"
                        ValueChanged="SeekSlider_ValueChanged"
                        VerticalAlignment="Center" />

                <TextBlock x:Name="TotalTimeText"
                           Grid.Column="2"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Grid>

        <!-- Transport controls -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Padding="0,4,0,8">

            <Button Click="Stop_Click"
                    ToolTipService.ToolTip="Stop"
                    Padding="8">
                <FontIcon Glyph="&#xE71A;" FontSize="16" />
            </Button>

            <Button x:Name="PlayPauseButton"
                    Click="PlayPause_Click"
                    ToolTipService.ToolTip="Play / Pause"
                    Padding="12,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="20" />
            </Button>

            <AppBarSeparator />

            <!-- Volume -->
            <FontIcon Glyph="&#xE767;" FontSize="14" VerticalAlignment="Center" />
            <Slider x:Name="VolumeSlider"
                    Width="100"
                    Minimum="0" Maximum="100"
                    Value="80"
                    ValueChanged="VolumeSlider_ValueChanged"
                    VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
