<UserControl
    x:Class="VideoArchive.Views.PlayerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="0,1,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Back to search header -->
        <Grid Grid.Row="0" Padding="8,6" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Button x:Name="BackToSearchButton"
                    Click="BackToSearch_Click"
                    ToolTipService.ToolTip="Back to Search"
                    Padding="6,4"
                    Background="Transparent"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="Back to Search" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Video surface area (native popup window renders on top of this) -->
        <Border x:Name="VideoSurface"
                Grid.Row="1"
                Background="Black"
                MinHeight="180"
                SizeChanged="VideoSurface_SizeChanged"
                DoubleTapped="VideoSurface_DoubleTapped">
            <!-- "No video" placeholder -->
            <StackPanel x:Name="NoVideoPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE714;"
                          FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Select a video and click Play"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Now playing + seek bar -->
        <Grid Grid.Row="2" Padding="12,8,12,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="NowPlayingText"
                       Grid.Row="0"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,4" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <Slider x:Name="SeekSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="1"
                        StepFrequency="0.001"
                        ThumbToolTipValueConverter="{x:Null}"
                        ValueChanged="SeekSlider_ValueChanged"
                        VerticalAlignment="Center" />

                <TextBlock x:Name="TotalTimeText"
                           Grid.Column="2"
                           Text="--:--"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Grid>

        <!-- Transport controls -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Padding="0,4,0,8">

            <Button Click="Stop_Click"
                    ToolTipService.ToolTip="Stop"
                    Padding="8">
                <FontIcon Glyph="&#xE71A;" FontSize="16" />
            </Button>

            <Button x:Name="PlayPauseButton"
                    Click="PlayPause_Click"
                    ToolTipService.ToolTip="Play / Pause"
                    Padding="12,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="20" />
            </Button>

            <ToggleButton x:Name="LoopButton"
                          Click="LoopToggle_Click"
                          ToolTipService.ToolTip="Loop"
                          Padding="8">
                <FontIcon Glyph="&#xE8EE;" FontSize="16" />
            </ToggleButton>

            <AppBarSeparator />

            <!-- Volume -->
            <FontIcon Glyph="&#xE767;" FontSize="14" VerticalAlignment="Center" />
            <Slider x:Name="VolumeSlider"
                    Width="100"
                    Minimum="0" Maximum="100"
                    Value="80"
                    ValueChanged="VolumeSlider_ValueChanged"
                    VerticalAlignment="Center" />

            <AppBarSeparator />

            <!-- Fullscreen toggle -->
            <Button x:Name="FullscreenButton"
                    Click="Fullscreen_Click"
                    ToolTipService.ToolTip="Fullscreen (double-click video or press Escape to exit)"
                    Padding="8">
                <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="16" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
