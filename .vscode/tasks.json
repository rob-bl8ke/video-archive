{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\src\\VideoArchive\\VideoArchive.csproj",
        "-c",
        "Debug",
        "-p:Platform=x64"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-release",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}\\src\\VideoArchive\\VideoArchive.csproj",
        "-c",
        "Release",
        "-p:Platform=x64"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "type": "process",
      "command": "dotnet",
      "args": [
        "clean",
        "${workspaceFolder}\\src\\VideoArchive\\VideoArchive.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "restore",
        "${workspaceFolder}\\src\\VideoArchive\\VideoArchive.csproj"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
